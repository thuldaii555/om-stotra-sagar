# Never commit .env.
# Never commit a real GitHub token or real admin password.

# Frontend build variable
# This value is bundled into the frontend. It is only a simple UI gate,
# not real security.
VITE_ADMIN_PASSCODE=

# Server-only Netlify Function variables
# ADMIN_PASSWORD belongs only in Netlify environment variables or local netlify dev.
# GITHUB_TOKEN belongs only in Netlify environment variables or local netlify dev.
# Do not expose these values in frontend code.
ADMIN_PASSWORD=
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_CONTENT_PATH=data/om-stotra-content.json
